# Discord application credentials (Developer Portal -> your app -> OAuth2).
# VITE_DISCORD_CLIENT_ID is public and baked into the client bundle at build
# time; DISCORD_CLIENT_SECRET is server-only — never expose it to the client.
VITE_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Custom launch card (scoreboard message + Play button). Both optional; when
# unset the /interactions endpoint and scoreboard posting are disabled.
# DISCORD_PUBLIC_KEY: Developer Portal -> General Information -> Public Key.
# DISCORD_BOT_TOKEN:  Developer Portal -> Bot -> Token. Needed to post/edit
# the scoreboard message in channels. After deploying, run
# `npm run configure-entry-point` once and set the Interactions Endpoint URL
# (https://<host>/interactions) in General Information.
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Cloudflare Tunnel token for the activity's public hostname (docker compose
# only; see DEPLOYMENT.md §4).
TUNNEL_TOKEN=

# Optional overrides.
# PORT=3000
# Skill icon host used when running OUTSIDE Discord (inside Discord the client
# always goes through the /.proxy/haku URL mapping instead). See
# DEPLOYMENT.md §6 for hosting options.
# VITE_RESOURCE_BASE=https://icons.example.com
