{
  "name": "mapledoro-discord-activity",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node --env-file-if-exists=.env --watch server/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "start": "node --env-file-if-exists=.env server/index.ts",
    "configure-entry-point": "node --env-file-if-exists=.env scripts/configure-entry-point.mjs"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@discord/embedded-app-sdk": "^2.5.0",
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/nunito": "^5.2.7",
    "@types/express": "^5.0.6",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
